<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.guowei.ordering.mapper.CategoryMapper">
    <select id="selectEnabledList" resultType="com.guowei.ordering.vo.CategoryVO">
        SELECT id, name, sort
        FROM category
        WHERE status = 1
        ORDER BY sort ASC, id ASC
    </select>
</mapper>
