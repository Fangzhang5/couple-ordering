/* pages/menu.wxss */
.menu-page {
  display: flex;
  height: 100vh;
  background-color: #ffffff;
}

.category-list {
  width: 180rpx;
  height: 100%;
  background-color: #f5f5f5;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;

  height: 100rpx;

  color: #666666;
  font-size: 28rpx;
}

.category-item.active {
  color: #222222;
  font-weight: bold;
  background-color: #ffffff;
  border-left: 8rpx solid #ff7a45;
}

.dish-list {
  flex: 1;
  padding: 30rpx;

  color: #999999;
  font-size: 28rpx;
}

.dish-item {
  display: flex;

  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.dish-image {
  width: 180rpx;
  height: 150rpx;

  flex-shrink: 0;

  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.dish-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;

  background-color: #fff2e8;
  font-size: 64rpx;
}

.dish-content {
  display: flex;
  flex: 1;
  flex-direction: column;

  min-width: 0;
  padding-left: 22rpx;
}

.dish-name {
  overflow: hidden;

  color: #222222;
  font-size: 32rpx;
  font-weight: bold;

  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-description {
  display: -webkit-box;
  overflow: hidden;

  margin-top: 12rpx;

  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;

  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;

  margin-top: auto;
}

.dish-price {
  color: #ff5a36;
  font-size: 32rpx;
  font-weight: bold;
}

.currency {
  margin-right: 2rpx;
  font-size: 22rpx;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 52rpx;
  height: 52rpx;

  border-radius: 50%;
  background-color: #ffc300;

  color: #222222;
  font-size: 40rpx;
  font-weight: bold;
  line-height: 52rpx;
}

.dish-cart-control {
  display: flex;
  align-items: center;
  justify-content: flex-end;

  height: 52rpx;
  flex-shrink: 0;
}

.minus-button {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 48rpx;
  height: 48rpx;
  box-sizing: border-box;

  border: 2rpx solid #dddddd;
  border-radius: 50%;
  background-color: #ffffff;

  color: #333333;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 48rpx;
}

.cart-quantity {
  min-width: 42rpx;
  margin: 0 10rpx;

  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  line-height: 52rpx;
}

.cart-button-disabled {
  opacity: 0.45;
}

.page-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  height: 100vh;

  color: #999999;
  font-size: 28rpx;
}

.dish-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  height: 300rpx;

  color: #999999;
  font-size: 26rpx;
}

.empty-icon {
  margin-bottom: 20rpx;
  font-size: 70rpx;
}

.empty-title {
  color: #555555;
  font-size: 30rpx;
  font-weight: bold;
}

.empty-description {
  margin-top: 16rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}

.cart-bar {
  position: fixed;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 100;

  display: flex;
  align-items: center;

  height: 106rpx;
  padding: 0 14rpx 0 22rpx;
  box-sizing: border-box;

  border-radius: 56rpx;
  background-color: #222222;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.22);
}

.cart-icon-wrapper {
  position: relative;

  display: flex;
  align-items: center;
  justify-content: center;

  width: 78rpx;
  height: 78rpx;
  flex-shrink: 0;

  border-radius: 50%;
  background-color: #333333;
}

.cart-icon {
  font-size: 45rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;

  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;

  border-radius: 18rpx;
  background-color: #ff5a36;

  color: #ffffff;
  font-size: 21rpx;
  line-height: 34rpx;
  text-align: center;
}

.cart-info {
  display: flex;
  flex: 1;
  flex-direction: column;

  min-width: 0;
  margin-left: 22rpx;
}

.cart-amount {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.cart-tip {
  margin-top: 4rpx;
  color: #aaaaaa;
  font-size: 22rpx;
}

.checkout-button {
  width: 190rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;

  border-radius: 40rpx;
  background-color: #ff7a45;

  color: #ffffff;
  font-size: 29rpx;
  font-weight: bold;
  line-height: 76rpx;
}

.checkout-button::after {
  border: none;
}

.checkout-button-disabled {
  background-color: #555555;
  color: #aaaaaa;
}