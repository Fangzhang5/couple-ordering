/* pages/cart.wxss */
.cart-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 230rpx;
  box-sizing: border-box;
  background-color: #f7f7f7;
}

.cart-list {
  overflow: hidden;
  border-radius: 24rpx;
  background-color: #ffffff;
}

.cart-item {
  display: flex;
  padding: 28rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.cart-item:last-child {
  border-bottom: none;
}

.dish-image {
  width: 160rpx;
  height: 140rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.dish-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff2e8;
  font-size: 58rpx;
}

.dish-content {
  display: flex;
  flex: 1;
  flex-direction: column;

  min-width: 0;
  padding-left: 24rpx;
}

.dish-name {
  overflow: hidden;
  color: #222222;
  font-size: 32rpx;
  font-weight: bold;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-price {
  display: flex;
  align-items: center;
  height: 46rpx;
  flex-shrink: 0;
  color: #ff5a36;
  font-size: 28rpx;
  line-height: 1;
}

.price-control-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;

  margin-top: 18rpx;
}

.amount-row {
  display: flex;
  justify-content: flex-end;

  margin-top: 18rpx;
}

.quantity-control {
  display: flex;
  align-items: center;

  width: 156rpx;
  height: 46rpx;
  flex-shrink: 0;

  overflow: hidden;
  border: 1rpx solid #eeeeee;
  border-radius: 24rpx;
  background-color: #ffffff;
  transform: translateY(8rpx);
}

.quantity-button {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
  box-sizing: border-box;

  color: #333333;
  font-size: 28rpx;
  line-height: 1;
}

.quantity-number {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 64rpx;
  height: 46rpx;
  flex-shrink: 0;
  box-sizing: border-box;

  color: #333333;
  font-size: 25rpx;
  line-height: 1;
}

.quantity-button-disabled {
  color: #cccccc;
  background-color: #fafafa;
}

.item-amount {
  color: #333333;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 32rpx;
  text-align: right;
}

.cart-footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;

  display: flex;
  align-items: center;

  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;

  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.summary {
  flex: 1;
}

.summary-count {
  display: block;
  color: #999999;
  font-size: 22rpx;
}

.total-price {
  display: flex;
  align-items: baseline;
  margin-top: 6rpx;
}

.total-label {
  color: #555555;
  font-size: 26rpx;
}

.currency {
  color: #ff5a36;
  font-size: 24rpx;
  font-weight: bold;
}

.total-number {
  color: #ff5a36;
  font-size: 38rpx;
  font-weight: bold;
}

.checkout-button {
  width: 210rpx;
  margin: 0;
  border-radius: 50rpx;
  background-color: #ff7a45;
  color: #ffffff;
  font-size: 30rpx;
}

.checkout-button::after {
  border: none;
}

.page-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  min-height: 100vh;
  padding: 50rpx;
  box-sizing: border-box;

  color: #999999;
}

.state-icon {
  margin-bottom: 20rpx;
  font-size: 70rpx;
}

.state-title {
  color: #555555;
  font-size: 30rpx;
  font-weight: bold;
}

.state-description {
  margin-top: 14rpx;
  font-size: 24rpx;
}

.retry-button {
  margin-top: 30rpx;
  border-radius: 30rpx;
  background-color: #ff7a45;
  color: #ffffff;
}
