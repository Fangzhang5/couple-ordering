/* pages/menu/dish-detail.wxss */
.detail-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background-color: #f7f7f7;
}

.dish-image {
  width: 100%;
  height: 500rpx;
  background-color: #f5f5f5;
}

.dish-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;

  background-color: #fff2e8;
  font-size: 140rpx;
}

.detail-card {
  margin: -30rpx 24rpx 0;
  padding: 34rpx;

  position: relative;

  border-radius: 28rpx;
  background-color: #ffffff;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;

  gap: 24rpx;
}

.dish-name {
  flex: 1;
  min-width: 0;

  color: #222222;
  font-size: 40rpx;
  font-weight: bold;

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-price {
  display: flex;
  align-items: baseline;

  flex-shrink: 0;
  white-space: nowrap;

  color: #ff5a36;
  font-weight: bold;
}

.currency {
  margin-right: 4rpx;
  font-size: 24rpx;
}

.price-number {
  font-size: 40rpx;
}

.category-tag {
  display: inline-block;

  margin-top: 22rpx;
  padding: 8rpx 20rpx;

  border-radius: 24rpx;
  background-color: #fff0e8;

  color: #e85c22;
  font-size: 24rpx;
}

.description-section {
  margin-top: 40rpx;
}

.section-title {
  display: block;

  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
}

.dish-description {
  display: block;

  margin-top: 18rpx;

  color: #777777;
  font-size: 28rpx;
  line-height: 44rpx;
}

.page-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  min-height: 100vh;
  padding: 50rpx;
  box-sizing: border-box;

  color: #999999;
}

.state-icon {
  margin-bottom: 20rpx;
  font-size: 70rpx;
}

.state-title {
  color: #555555;
  font-size: 30rpx;
  font-weight: bold;
}

.state-description {
  margin-top: 14rpx;

  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}