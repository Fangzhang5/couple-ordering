/* pages/menu.wxss */
.menu-page {
  display: flex;
  height: 100vh;
  background-color: #ffffff;
}

.category-list {
  width: 180rpx;
  height: 100%;
  background-color: #f5f5f5;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;

  height: 100rpx;

  color: #666666;
  font-size: 28rpx;
}

.category-item.active {
  color: #222222;
  font-weight: bold;
  background-color: #ffffff;
  border-left: 8rpx solid #ff7a45;
}

.dish-list {
  flex: 1;
  padding: 30rpx;

  color: #999999;
  font-size: 28rpx;
}

.dish-item {
  display: flex;

  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.dish-image {
  width: 180rpx;
  height: 150rpx;

  flex-shrink: 0;

  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.dish-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;

  background-color: #fff2e8;
  font-size: 64rpx;
}

.dish-content {
  display: flex;
  flex: 1;
  flex-direction: column;

  min-width: 0;
  padding-left: 22rpx;
}

.dish-name {
  overflow: hidden;

  color: #222222;
  font-size: 32rpx;
  font-weight: bold;

  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-description {
  display: -webkit-box;
  overflow: hidden;

  margin-top: 12rpx;

  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;

  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;

  margin-top: auto;
}

.dish-price {
  color: #ff5a36;
  font-size: 32rpx;
  font-weight: bold;
}

.currency {
  margin-right: 2rpx;
  font-size: 22rpx;
}

.detail-button {
  padding: 10rpx 22rpx;

  border-radius: 28rpx;
  background-color: #ff7a45;

  color: #ffffff;
  font-size: 24rpx;
}

.page-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  height: 100vh;

  color: #999999;
  font-size: 28rpx;
}

.dish-state {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;

  height: 300rpx;

  color: #999999;
  font-size: 26rpx;
}

.empty-icon {
  margin-bottom: 20rpx;
  font-size: 70rpx;
}

.empty-title {
  color: #555555;
  font-size: 30rpx;
  font-weight: bold;
}

.empty-description {
  margin-top: 16rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}